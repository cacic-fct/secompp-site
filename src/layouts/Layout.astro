---
import { Font } from 'astro:assets';
import Footer from '../components/Footer.astro';
import Nav from '../components/Nav.astro';
import '../styles/global.pcss';

interface Props {
  title: string;
  description?: string;
}

const defaultDescription = 'A Semana da Computação de Presidente Prudente oferece minicursos, palestras e mais!';

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="pt-br">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/images/favicon.png" />

    <title>{title}</title>
    <meta name="description" content={description || defaultDescription} />
    <Font cssVariable="--font-inter" />

    <!-- OGP: Open Graph -->
    <meta property="og:locale" content="pt_BR" />
    <meta property="og:url" content="https://secompp.cacic.dev.br" />
    <meta property="og:title" content="SECOMPP24" />
    <meta property="og:site_name" content="SECOMPP24" />
    <meta property="og:type" content="website" />
    <meta property="og:description" content={description || defaultDescription} />
    <meta property="og:image" content="https://secompp.cacic.dev.br/images/logo-og.png" />

    <!-- Analytics -->
    <script defer is:inline src="https://a.cacic.dev.br/b.js" data-website-id="7648931d-e076-44ff-b7eb-714602e2cc20"
    ></script>
    <script
      defer
      is:inline
      src="https://a.cacic.dev.br/recorder.js"
      data-website-id="7648931d-e076-44ff-b7eb-714602e2cc20"
      data-sample-rate="1"
      data-mask-level="moderate"
      data-max-duration="1200000"></script>
  </head>
  <body>
    <Nav />
    <slot />
    <Footer />
  </body>
</html>

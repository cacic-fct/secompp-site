{
  "name": "astr",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build:analytics": "mkdir -p public/js && bun build src/analytics/cacic-umami-tracking.ts --target=browser --format=iife --outfile=public/js/cacic-umami-tracking.js --minify",
    "build": "bun run build:analytics && astro check && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "prepare": "husky",
    "lint": "prettier --check . && eslint 'src/**/*.{js,astro,ts,svelte}'"
  },
  "dependencies": {
    "@astrojs/check": "0.9.9",
    "@astrojs/sitemap": "3.7.3",
    "@astrojs/svelte": "9.0.0",
    "@cacic-fct/account-manager-cookie-banner": "^0.1.1",
    "@cacic-fct/account-manager-privacy": "^0.1.4",
    "@fontsource-variable/inter": "^5.2.8",
    "@twemoji/parser": "^17.0.2",
    "astro": "7.0.4",
    "date-fns": "^4.4.0",
    "lucide-astro": "^0.471.0",
    "lucide-svelte": "^0.471.0",
    "sharp": "^0.34.5",
    "svelte": "^5.56.4",
    "typescript": "^5.9.3",
    "unleash-proxy-client": "^3.8.0"
  },
  "devDependencies": {
    "@esbuild/linux-x64": "^0.25.12",
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^22.20.0",
    "@typescript-eslint/parser": "^8.62.1",
    "daisyui": "^5.6.6",
    "eslint": "^9.39.4",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-svelte": "^2.46.1",
    "globals": "^15.15.0",
    "husky": "^9.1.7",
    "postcss": "^8.5.16",
    "postcss-import": "^16.1.1",
    "prettier": "3.6.2",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-svelte": "^3.5.2",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "tailwindcss": "^4.3.2",
    "typescript-eslint": "^8.62.1"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.62.2"
  },
  "trustedDependencies": [
    "sharp"
  ]
}
